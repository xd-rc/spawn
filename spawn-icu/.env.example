# ---------------------------------------------------------------------------
# Spawn.icu environment variables
# Copy this file to ".env" for local development and fill in real values.
# NEVER commit your real .env file. These secrets must stay server-side only.
# ---------------------------------------------------------------------------

# Discord bot token (from the Discord Developer Portal -> Bot -> Reset Token).
# Treat this like a password. It is only ever read on the server.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your personal Discord user ID (enable Developer Mode in Discord, right-click
# your name -> Copy User ID). The bot DMs this user on each new submission.
DISCORD_OWNER_ID=your_discord_user_id_here

# Optional: max submissions allowed per IP within the rate-limit window.
RATE_LIMIT_MAX=5
# Optional: rate-limit window length in seconds.
RATE_LIMIT_WINDOW_SECONDS=600
